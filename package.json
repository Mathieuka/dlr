{
  "name": "@mathieuka/dlr",
  "version": "0.1.1",
  "description": "Give your LLM coding agent a persistent memory across sessions.",
  "type": "module",
  "bin": {
    "dlr": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cli",
    "llm",
    "agent",
    "decision-log",
    "memory",
    "context",
    "agentic",
    "developer-tools"
  ],
  "author": "Mathieu Kahlaoui <mathieu@fabriq.fr>",
  "license": "MIT",
  "homepage": "https://github.com/Mathieuka/dlr#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mathieuka/dlr.git"
  },
  "bugs": {
    "url": "https://github.com/Mathieuka/dlr/issues"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
